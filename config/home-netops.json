{
  "shared": {
    "PUBLIC_IP_URLS": "https://ip.3322.net https://ddns.oray.com/checkip https://myip.ipip.net",
    "PUBLIC_IP_TIMEOUT": "8",
    "PUBLIC_IP_NO_PROXY": "1"
  },
  "services": {
    "ddns": {
      "ALIYUN_BIN": "aliyun",
      "ALIYUN_PROFILE": "ddns",
      "ALIYUN_DOMAIN_NAME": "bigbug.ren",
      "ALIYUN_RR": "home",
      "ALIYUN_TYPE": "A",
      "ALIYUN_LINE": "default",
      "ALIYUN_TTL": "600"
    },
    "firewall": {
      "TCCLI_BIN": ".venv/bin/tccli",
      "TENCENT_INSTANCE_ID": "lhins-33uux3hm",
      "TENCENT_REGION": "ap-beijing",
      "TENCENT_FIREWALL_RULE_DESC_PREFIX": "home-netops: ",
      "TENCENT_FIREWALL_RULES": [
        {
          "Protocol": "TCP",
          "Port": "22",
          "Action": "ACCEPT",
          "FirewallRuleDescription": "auto-wsl-home-ssh"
        },
        {
          "Protocol": "TCP",
          "Port": "11010-11012",
          "Action": "ACCEPT",
          "FirewallRuleDescription": "easytier-home"
        },
        {
          "Protocol": "UDP",
          "Port": "11010",
          "Action": "ACCEPT",
          "FirewallRuleDescription": "easytier-home"
        },
        {
          "Protocol": "TCP",
          "Port": "21114-21119",
          "Action": "ACCEPT",
          "FirewallRuleDescription": "RustDesk"
        },
        {
          "Protocol": "UDP",
          "Port": "21116",
          "Action": "ACCEPT",
          "FirewallRuleDescription": "RustDesk"
        }
      ],
      "RESTART_REVERSE_AFTER_FIREWALL_CHANGE": "1",
      "SYSTEMCTL_BIN": "systemctl"
    },
    "reverse-ssh": {
      "AUTOSSH_BIN": "autossh",
      "CLOUD_HOST": "82.156.118.129",
      "CLOUD_USER": "root",
      "CLOUD_PORT": "22",
      "REMOTE_BIND_ADDR": "127.0.0.1",
      "REMOTE_BIND_PORT": "2222",
      "LOCAL_TARGET_HOST": "127.0.0.1",
      "LOCAL_TARGET_PORT": "22",
      "IDENTITY_FILE": "",
      "CHECK_LOCAL_SSHD": "1"
    },
    "easytier": {
      "EASYTIER_BIN": "easytier-core"
    },
    "proxy-server": {
      "GOST_BIN": "gost",
      "EASYTIER_LAN_IP": "",
      "PROXY_SOCKS_PORT": "1080",
      "PROXY_HTTP_PORT": "8080"
    },
    "proxy-client": {
      "GOST_BIN": "gost",
      "PROXY_CLIENT_LISTEN_ADDR": "127.0.0.1",
      "PROXY_SERVER_IP": "10.144.144.3",
      "PROXY_SOCKS_PORT": "1080",
      "PROXY_HTTP_PORT": "8080"
    }
  },
  "roles": {
    "home": {
      "services": ["ddns", "firewall", "easytier", "proxy-client"],
      "overrides": {
        "easytier": {
          "EASYTIER_CONFIG": "config/easytier-home.local.yaml"
        }
      }
    },
    "ali": {
      "services": ["easytier", "proxy-server"],
      "overrides": {
        "easytier": {
          "EASYTIER_CONFIG": "config/easytier-ali.local.yaml"
        }
      }
    },
    "tencent": {
      "services": ["easytier"],
      "overrides": {
        "easytier": {
          "EASYTIER_CONFIG": "config/easytier-tencent.local.yaml"
        }
      }
    }
  }
}
