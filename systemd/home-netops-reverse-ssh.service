[Unit]
Description=home-netops reverse SSH tunnel
After=network-online.target home-netops-tencent-firewall.service
Wants=network-online.target
Requires=home-netops-tencent-firewall.service

[Service]
Type=simple
User=root
Group=root
EnvironmentFile=-/etc/home-netops/home-netops.conf
ExecStart=/usr/local/lib/home-netops/reverse-ssh.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
